# ================================================
# Arquivo de variáveis de ambiente - EXEMPLO
# Copie para .env e preencha com seus dados reais
# ================================================

# Banco de Dados
# SQLite (padrão, sem configuração adicional):
DATABASE_URL=sqlite:///./assistente_financeiro.db

# PostgreSQL (produção):
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/assistente_financeiro

# Telegram Bot (integração futura)
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui
TELEGRAM_ALLOW_AUTO_BIND=true
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_AGENDA_REMINDERS_ENABLED=true
TELEGRAM_AGENDA_POLL_SECONDS=60
TELEGRAM_AGENDA_JANELA_MIN=15
TELEGRAM_COMPROMISSO_LEMBRETE_PADRAO_MIN=60
TELEGRAM_EVENTO_ANTECEDENCIA_HORAS=24
TELEGRAM_PLANNER_LEMBRETE_HORA=8

# IA local gratuita para conversa no Telegram (Ollama - https://github.com/ollama/ollama)
TELEGRAM_AI_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=90
TELEGRAM_AI_MAX_CONTEXT=12
# TELEGRAM_AI_SYSTEM_PROMPT=Opcional: personalize o estilo de resposta do bot

# Google Gemini - Assistente Vorcaro (obtenha em aistudio.google.com)
GEMINI_API_KEY=sua_chave_gemini_aqui

# Fallback local e gratuito do Vorcaro (Ollama)
VORCARO_LOCAL_AI_ENABLED=true
VORCARO_OLLAMA_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=180

# Fallback online gratuito do Vorcaro (OpenRouter)
VORCARO_OPENROUTER_ENABLED=true
OPENROUTER_API_KEY=sua_chave_openrouter_aqui
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_TIMEOUT_SECONDS=45

# Voz local gratuita (Whisper local em cascata)
VOICE_MODEL_PRIMARY=small
VOICE_MODEL_RESERVE=tiny
VOICE_MODEL_LUXURY=large-v3
VOICE_DEVICE=auto
VOICE_COMPUTE_TYPE=int8
VOICE_MIN_TEXT_CHARS=6

# Configurações do servidor
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Frequências de memes automáticos
TELEGRAM_MEME_AUTO_CHANCE=0.35
GUI_MEME_AUTO_CHANCE=0.45

# Logo principal do ecossistema LOGOS
# Pode ser absoluto ou relativo à raiz do projeto.
# Exemplo: SISTEMA_LOGO_PATH=assistente_financeiro/assets/logo_sistema.png
# SISTEMA_LOGO_PATH=assistente_financeiro/assets/logo_sistema.png

# Pasta de uploads
UPLOAD_DIR=uploads
